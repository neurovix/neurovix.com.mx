---
import { Image } from "astro:assets";
import BlackLogo from "/public/black_logo.png";
import ArrowDown from "/public/arrow-down.png";
import ArrowUp from "/public/arrow-up.png";
---

<nav class="flex flex-row items-center w-full px-10 py-3">
  <div class="w-2/12 flex justify-end">
    <Image src={BlackLogo} alt="Imagen de logo" class="w-36" />
  </div>
  <div class="w-7/12">
    <ul class="flex flex-row items-center justify-center">
      <li class="flex flex-row items-center mx-3"><a class="mr-2">Servicios</a><Image src={ArrowDown} alt="dropdown" class="w-3" /></li>
      <li class="flex flex-row items-center mx-3"><a class="mr-2">Porque nosotros</a><Image src={ArrowDown} alt="dropdown" class="w-3" /></li>
      <li class="flex flex-row items-center mx-3"><a class="mr-2">Nuestros projectos</a><Image src={ArrowDown} alt="dropdown" class="w-3" /></li>
      <li class="flex flex-row items-center mx-3"><a class="mr-2">Soluciones</a><Image src={ArrowDown} alt="dropdown" class="w-3" /></li>
      <li class="flex flex-row items-center mx-3"><a class="mr-2">Precios</a></li>
    </ul>
  </div>
  <div class="w-3/12 flex flex-row items-center">
    <a class="hover:cursor-pointer mr-3 bg-white px-2 py-3 hover:bg-cyan-600 hover:text-white hover:border-[1px] hover:border-cyan-400 rounded-2xl border-[1px] shadow shadow-gray-500 border-gray-600">Contactanos</a>
    <a class="bg-cyan-600 px-2 py-3 hover:cursor-pointer hover:bg-cyan-800 rounded-2xl text-white">Agenda una llamada</a>
  </div>
</nav>
